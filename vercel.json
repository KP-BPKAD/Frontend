{
  "trailingSlash": false,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "redirects": [],
  "rewrites": [
    {
      "source": "/((?!api|_next/static|_next/image|assets|favicon.ico|manifest.json|Gambar).*)",
      "destination": "/index.html"
    }
  ]
}